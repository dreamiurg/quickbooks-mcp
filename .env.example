# QuickBooks MCP Server Configuration

# ═══════════════════════════════════════════════════════════════════════════════
# CREDENTIAL MODE
# ═══════════════════════════════════════════════════════════════════════════════
# Choose how credentials are stored:
#   - "local" (default): Store in ~/.quickbooks-mcp/credentials.json
#   - "aws": Use AWS Secrets Manager and SSM Parameter Store
# QBO_CREDENTIAL_MODE=local

# ═══════════════════════════════════════════════════════════════════════════════
# LOCAL MODE CONFIGURATION (QBO_CREDENTIAL_MODE=local or not set)
# ═══════════════════════════════════════════════════════════════════════════════
# Your QuickBooks app client credentials (from developer.intuit.com)
# QBO_CLIENT_ID=your_client_id
# QBO_CLIENT_SECRET=your_client_secret

# Optional: Custom path for credentials file (default: ~/.quickbooks-mcp/credentials.json)
# QBO_CREDENTIAL_FILE=/custom/path/to/credentials.json

# ═══════════════════════════════════════════════════════════════════════════════
# AWS MODE CONFIGURATION (QBO_CREDENTIAL_MODE=aws)
# ═══════════════════════════════════════════════════════════════════════════════
# AWS credentials are loaded from environment or ~/.aws/credentials
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-2

# QuickBooks credentials stored in AWS Secrets Manager
# Secret should contain JSON: { client_id, client_secret, access_token, refresh_token, redirect_url }
QBO_SECRET_NAME=prod/qbo

# Company ID stored in SSM Parameter Store
QBO_COMPANY_ID_PARAM=/prod/qbo/company_id

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════
# Use QuickBooks sandbox environment (default: false / production)
# QBO_SANDBOX=true
